{
    "tabOrder_append": "lua",
    "languages_entry": {
        "lua": {
            "displayName": "Lua (LuaJIT)",
            "platforms": {
                "linux": {
                    "description": "Download azul.lua and the native library, then run with LuaJIT",
                    "steps": [
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/libazul.so"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/azul.lua"
                        },
                        {
                            "type": "command",
                            "content": "LD_LIBRARY_PATH=. luajit hello-world.lua"
                        }
                    ]
                },
                "macos": {
                    "description": "Download azul.lua and the native library, then run with LuaJIT",
                    "steps": [
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/libazul.dylib"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/azul.lua"
                        },
                        {
                            "type": "command",
                            "content": "DYLD_LIBRARY_PATH=. luajit hello-world.lua"
                        }
                    ]
                },
                "windows": {
                    "description": "Download azul.lua and the native library, then run with LuaJIT",
                    "steps": [
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/azul.dll"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/azul.lua"
                        },
                        {
                            "type": "command",
                            "content": "luajit hello-world.lua"
                        }
                    ]
                }
            }
        }
    },
    "examples_code_additions": {
        "hello-world": "lua/hello-world.lua"
    }
}
