{
    "tabOrder_append": "java",
    "languages_entry": {
        "java": {
            "displayName": "Java",
            "platforms": {
                "linux": {
                    "description": "Download azul, build the JNA-bound JAR with Maven",
                    "steps": [
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/libazul.so"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/azul-java.zip"
                        },
                        {
                            "type": "command",
                            "content": "unzip azul-java.zip"
                        },
                        {
                            "type": "command",
                            "content": "mkdir -p src/main/resources/linux-x86-64 && mv libazul.so src/main/resources/linux-x86-64/"
                        },
                        {
                            "type": "command",
                            "content": "mvn -f pom.xml package"
                        },
                        {
                            "type": "command",
                            "content": "java -cp target/azul-1.0.0.jar:$(mvn dependency:build-classpath -q -Dmdep.outputFile=/dev/stdout) HelloWorld"
                        }
                    ]
                },
                "macos": {
                    "description": "Download azul, build the JNA-bound JAR with Maven",
                    "steps": [
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/libazul.dylib"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/azul-java.zip"
                        },
                        {
                            "type": "command",
                            "content": "unzip azul-java.zip"
                        },
                        {
                            "type": "command",
                            "content": "mkdir -p src/main/resources/darwin && mv libazul.dylib src/main/resources/darwin/"
                        },
                        {
                            "type": "command",
                            "content": "mvn -f pom.xml package"
                        },
                        {
                            "type": "command",
                            "content": "java -cp target/azul-1.0.0.jar:$(mvn dependency:build-classpath -q -Dmdep.outputFile=/dev/stdout) HelloWorld"
                        }
                    ]
                },
                "windows": {
                    "description": "Download azul, build the JNA-bound JAR with Maven",
                    "steps": [
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/azul.dll"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/azul-java.zip"
                        },
                        {
                            "type": "command",
                            "content": "tar -xf azul-java.zip"
                        },
                        {
                            "type": "command",
                            "content": "mkdir src\\main\\resources\\win32-x86-64 && move azul.dll src\\main\\resources\\win32-x86-64\\"
                        },
                        {
                            "type": "command",
                            "content": "mvn -f pom.xml package"
                        },
                        {
                            "type": "command",
                            "content": "java -cp target\\azul-1.0.0.jar HelloWorld"
                        }
                    ]
                }
            }
        }
    },
    "examples_code_additions": {
        "hello-world": "java/HelloWorld.java"
    }
}
