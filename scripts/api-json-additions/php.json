{
    "tabOrder_append": "php",
    "languages_entry": {
        "php": {
            "displayName": "PHP",
            "platforms": {
                "linux": {
                    "description": "Download azul, install Azul.php and enable the PHP FFI extension",
                    "steps": [
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/libazul.so"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/Azul.php"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/composer.json"
                        },
                        {
                            "type": "command",
                            "content": "sudo apt-get install -y php-ffi || sudo dnf install -y php-ffi"
                        },
                        {
                            "type": "command",
                            "content": "php -d ffi.enable=true hello-world.php"
                        }
                    ]
                },
                "macos": {
                    "description": "Download azul, install Azul.php and enable the PHP FFI extension",
                    "steps": [
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/libazul.dylib"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/Azul.php"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/composer.json"
                        },
                        {
                            "type": "command",
                            "content": "brew install php"
                        },
                        {
                            "type": "command",
                            "content": "php -d ffi.enable=true hello-world.php"
                        }
                    ]
                },
                "windows": {
                    "description": "Download azul, install Azul.php and enable the PHP FFI extension",
                    "steps": [
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/azul.dll"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/Azul.php"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/composer.json"
                        },
                        {
                            "type": "command",
                            "content": "REM Enable the bundled FFI extension in php.ini: extension=ffi and ffi.enable=true"
                        },
                        {
                            "type": "command",
                            "content": "php -d ffi.enable=true hello-world.php"
                        }
                    ]
                }
            }
        }
    },
    "examples_code_additions": {
        "hello-world": "php/hello-world.php"
    }
}
