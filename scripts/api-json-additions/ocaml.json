{
    "tabOrder_append": "ocaml",
    "languages_entry": {
        "ocaml": {
            "displayName": "OCaml",
            "platforms": {
                "linux": {
                    "description": "Download azul + generated bindings, build with Dune",
                    "steps": [
                        {
                            "type": "command",
                            "content": "opam install ctypes ctypes-foreign"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/libazul.so"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/azul.ml"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/azul.mli"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/dune"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/dune-project"
                        },
                        {
                            "type": "command",
                            "content": "dune build && LD_LIBRARY_PATH=. ./_build/default/hello_world.exe"
                        }
                    ]
                },
                "macos": {
                    "description": "Download azul + generated bindings, build with Dune",
                    "steps": [
                        {
                            "type": "command",
                            "content": "opam install ctypes ctypes-foreign"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/libazul.dylib"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/azul.ml"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/azul.mli"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/dune"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/dune-project"
                        },
                        {
                            "type": "command",
                            "content": "dune build && DYLD_LIBRARY_PATH=. ./_build/default/hello_world.exe"
                        }
                    ]
                },
                "windows": {
                    "description": "Download azul + generated bindings, build with Dune (under MSYS2 / Cygwin OCaml)",
                    "steps": [
                        {
                            "type": "command",
                            "content": "opam install ctypes ctypes-foreign"
                        },
                        {
                            "type": "command",
                            "content": "curl -O %HOSTNAME%/release/%VERSION%/azul.dll"
                        },
                        {
                            "type": "command",
                            "content": "curl -O %HOSTNAME%/release/%VERSION%/azul.ml"
                        },
                        {
                            "type": "command",
                            "content": "curl -O %HOSTNAME%/release/%VERSION%/azul.mli"
                        },
                        {
                            "type": "command",
                            "content": "curl -O %HOSTNAME%/release/%VERSION%/dune"
                        },
                        {
                            "type": "command",
                            "content": "curl -O %HOSTNAME%/release/%VERSION%/dune-project"
                        },
                        {
                            "type": "command",
                            "content": "dune build && .\\_build\\default\\hello_world.exe"
                        }
                    ]
                }
            }
        }
    },
    "examples_code_additions": {
        "hello-world": "ocaml/hello_world.ml"
    }
}
