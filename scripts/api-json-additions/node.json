{
    "tabOrder_append": "node",
    "languages_entry": {
        "node": {
            "displayName": "Node.js (koffi)",
            "platforms": {
                "linux": {
                    "description": "Download azul prebuilt + install koffi",
                    "steps": [
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/libazul.so"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/azul.js"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/package.json"
                        },
                        {
                            "type": "command",
                            "content": "npm install"
                        },
                        {
                            "type": "command",
                            "content": "node hello-world.js"
                        }
                    ]
                },
                "macos": {
                    "description": "Download azul prebuilt + install koffi",
                    "steps": [
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/libazul.dylib"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/azul.js"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/package.json"
                        },
                        {
                            "type": "command",
                            "content": "npm install"
                        },
                        {
                            "type": "command",
                            "content": "node hello-world.js"
                        }
                    ]
                },
                "windows": {
                    "description": "Download azul prebuilt + install koffi",
                    "steps": [
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/azul.dll"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/azul.js"
                        },
                        {
                            "type": "command",
                            "content": "curl -O $HOSTNAME/release/$VERSION/package.json"
                        },
                        {
                            "type": "command",
                            "content": "npm install"
                        },
                        {
                            "type": "command",
                            "content": "node hello-world.js"
                        }
                    ]
                }
            }
        }
    },
    "examples_code_additions": {
        "hello-world": "node/hello-world.js"
    }
}
