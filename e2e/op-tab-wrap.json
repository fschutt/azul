{
  "name": "op_tab_wrap",
  "expect": "fail",
  "description": "FOCUS / TAB (wrap-around): with focus on the LAST focusable element (#f3), one more Tab must wrap back to the FIRST (#f1). azul's tab-order step is `(pos + 1) % len` (focus_cursor.rs step_focus), i.e. wrap-around, not clamp-at-end. Three Tabs walk f1→f2→f3, the fourth wraps to f1.",
  "setup": {
    "window_width": 400,
    "window_height": 300,
    "dpi": 96
  },
  "steps": [
    {
      "op": "mount",
      "html": [
        "<div id=\"root\">",
        "  <div id=\"f1\" tabindex=\"0\" class=\"item\">one</div>",
        "  <div id=\"f2\" tabindex=\"0\" class=\"item\">two</div>",
        "  <div id=\"f3\" tabindex=\"0\" class=\"item\">three</div>",
        "</div>"
      ],
      "css": [
        "html, body { margin: 0; padding: 0; }",
        "#root { display: flex; flex-direction: column; }",
        ".item { width: 120px; height: 30px; background: silver; font-family: \"Azul Mock Mono\"; font-size: 20px; }"
      ]
    },
    { "op": "wait_frame" },
    { "op": "wait", "ms": 200 },

    { "op": "assert_exists", "selector": "#f3" },

    { "op": "key_down", "key": "tab" },
    { "op": "key_up", "key": "tab" },
    { "op": "wait", "ms": 80 },
    { "op": "key_down", "key": "tab" },
    { "op": "key_up", "key": "tab" },
    { "op": "wait", "ms": 80 },
    { "op": "key_down", "key": "tab" },
    { "op": "key_up", "key": "tab" },
    { "op": "wait", "ms": 80 },
    { "op": "get_focus_state" },
    { "op": "assert_response", "contains": "f3" },

    { "op": "key_down", "key": "tab" },
    { "op": "key_up", "key": "tab" },
    { "op": "wait", "ms": 100 },
    { "op": "get_focus_state" },
    { "op": "assert_response", "type": "focus_state" },
    { "op": "assert_response", "contains": "f1" }
  ]
}
