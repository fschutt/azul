{
  "name": "op_dpi_changed",
  "description": "ZOMBIE-OP PROOF (dpi_changed): `dpi_changed` was declared with no match arm — the 96 [dpi/*] corpus lines were therefore ungeneratable, and any test using it would have been vacuously green. It now sets FullWindowState.size.dpi through CallbackChange::ModifyWindowState; apply_user_change() saves previous_window_state, applies the scale, tags RelayoutReason::Resize + frame_needs_regeneration (what WM_DPICHANGED and the X11 DPI path do) and runs the state-diff pass, and the op asks for the relayout+repaint a real scale change forces. Proof that it is not a no-op: the DPI and hidpi factor really change, the LOGICAL size stays put while the PHYSICAL/backing size rescales with it (400x300 @96 -> 800x600 @192 -> 500x375 @120), the frame is genuinely repainted (assert_changed compares real pixels), and the window then settles back to zero damage.",
  "setup": {
    "window_width": 400,
    "window_height": 300,
    "dpi": 96
  },
  "steps": [
    {
      "op": "mount",
      "html": [
        "<div id=\"root\"><p id=\"t\">DPI</p></div>"
      ],
      "css": [
        "html, body { margin: 0; padding: 0; width: 100%; height: 100%; }",
        "#root { width: 100%; height: 100%; background: red; }",
        "#t { font-size: 20px; color: white; }"
      ]
    },
    { "op": "wait_frame" },
    { "op": "wait", "ms": 200 },

    { "op": "assert_exists", "selector": "#root" },
    { "op": "assert_window_state", "property": "dpi", "expected": 96 },
    { "op": "assert_window_state", "property": "hidpi_factor", "expected": 1.0, "tolerance": 0.01 },
    { "op": "assert_window_state", "property": "physical_width", "expected": 400 },
    { "op": "assert_window_state", "property": "physical_height", "expected": 300 },

    { "op": "reset_frame_counters" },
    { "op": "snapshot_frame", "as": "at_96" },

    { "op": "dpi_changed", "dpi": 192 },
    { "op": "wait_frame" },
    { "op": "wait", "ms": 250 },
    { "op": "get_frame_report" },
    { "op": "capture_damage_png", "path": "target/e2e/op_dpi_changed_192.png" },

    { "op": "assert_window_state", "property": "dpi", "expected": 192 },
    { "op": "assert_window_state", "property": "hidpi_factor", "expected": 2.0, "tolerance": 0.01 },
    { "op": "assert_window_state", "property": "logical_width", "expected": 400 },
    { "op": "assert_window_state", "property": "logical_height", "expected": 300 },
    { "op": "assert_window_state", "property": "physical_width", "expected": 800 },
    { "op": "assert_window_state", "property": "physical_height", "expected": 600 },
    { "op": "assert_changed", "vs": "at_96", "min_damage_rects": 1 },

    { "op": "reset_frame_counters" },
    { "op": "snapshot_frame", "as": "at_192" },
    { "op": "tick_ms", "ms": 16 },
    { "op": "wait", "ms": 150 },
    { "op": "assert_idle_stable", "vs": "at_192" },

    { "op": "dpi_changed", "dpi": 120 },
    { "op": "wait_frame" },
    { "op": "wait", "ms": 250 },
    { "op": "assert_window_state", "property": "dpi", "expected": 120 },
    { "op": "assert_window_state", "property": "hidpi_factor", "expected": 1.25, "tolerance": 0.01 },
    { "op": "assert_window_state", "property": "physical_width", "expected": 500 },
    { "op": "assert_window_state", "property": "physical_height", "expected": 375 },
    { "op": "assert_changed", "vs": "at_192", "min_damage_rects": 1 },
    { "op": "assert_exists", "selector": "#t" }
  ]
}
