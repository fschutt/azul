{
  "name": "op_scroll_by_delta",
  "description": "SCROLLING (by delta): mount 10x 50px items (500px content) inside a 100px-tall overflow-y:scroll container. `scroll_node_by` delta_y=120 must move the container's scroll offset to y=120 (well within the 0..400 scroll range, so no clamp). assert_scroll reads scroll_manager.get_current_offset — a container that is not actually scrollable returns None and this goes red. Fixed pixel sizes (no text) keep the geometry deterministic without a font.",
  "setup": {
    "window_width": 400,
    "window_height": 300,
    "dpi": 96
  },
  "steps": [
    {
      "op": "mount",
      "html": [
        "<div id=\"scroller\">",
        "  <div class=\"row\" id=\"r0\"></div>",
        "  <div class=\"row\" id=\"r1\"></div>",
        "  <div class=\"row\" id=\"r2\"></div>",
        "  <div class=\"row\" id=\"r3\"></div>",
        "  <div class=\"row\" id=\"r4\"></div>",
        "  <div class=\"row\" id=\"r5\"></div>",
        "  <div class=\"row\" id=\"r6\"></div>",
        "  <div class=\"row\" id=\"r7\"></div>",
        "  <div class=\"row\" id=\"r8\"></div>",
        "  <div class=\"row\" id=\"r9\"></div>",
        "</div>"
      ],
      "css": [
        "html, body { margin: 0; padding: 0; }",
        "#scroller { width: 200px; height: 100px; overflow-y: scroll; }",
        ".row { width: 100%; height: 50px; background: blue; }"
      ]
    },
    { "op": "wait_frame" },
    { "op": "wait", "ms": 150 },

    { "op": "assert_exists", "selector": "#scroller" },
    { "op": "assert_node_count", "selector": ".row", "expected": 10 },

    { "op": "scroll_node_by", "selector": "#scroller", "delta_x": 0, "delta_y": 120 },
    { "op": "wait_frame" },
    { "op": "wait", "ms": 150 },

    { "op": "assert_scroll", "selector": "#scroller", "x": 0, "y": 120, "tolerance": 1.0 }
  ]
}
