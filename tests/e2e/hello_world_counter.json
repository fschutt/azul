      },
      {
        "op": "assert_text",
        "selector": "body > div",
        "expected": "6"
      },
      {
        "op": "click",
        "text": "Increase counter"
      },
      {
        "op": "wait",
        "ms": 300
      },
      {
        "op": "click",
        "text": "Increase counter"
      },
      {
        "op": "wait",
        "ms": 300
      },
      {
        "op": "assert_text",
        "selector": "body > div",
        "expected": "8"
      }
    ]
  }
