# Maintainer: Felix Schütt <felix.schuett@maps4print.com>
#
# AUR PKGBUILD for the Azul GUI framework's shared library (libazul).
#
# This builds the native C-ABI shared library from source with the stable
# Rust toolchain:
#
#     cargo build --release -p azul-dll --features build-dll
#
# and installs:
#   * /usr/lib/libazul.so          — the shared library (C ABI)
#   * /usr/include/azul/azul.h     — the C header (+ C++ headers)
#
# Language bindings (Python/Node/Ruby/C#/Java/...) are published to their
# own registries (PyPI/npm/RubyGems/NuGet/Maven) and load this libazul.so
# at runtime via FFI.
#
# `pkgver` is kept in sync with the workspace release version (0.2.0). The
# publish workflow rewrites `pkgver` and the source tag from the pushed git
# tag before deploying to the AUR.

pkgname=azul
pkgver=0.2.0
pkgrel=1
pkgdesc="Cross-platform GUI framework written in Rust (C-ABI shared library)"
arch=('x86_64' 'aarch64')
url="https://azul.rs/"
license=('MPL-2.0')
depends=('gcc-libs')
makedepends=('rust' 'cargo' 'clang' 'git' 'libx11' 'mesa')
provides=('libazul.so')
options=('!lto')
source=("$pkgname-$pkgver.tar.gz::https://github.com/maps4print/azul/archive/refs/tags/$pkgver.tar.gz")
# Updated by the release workflow / `updpkgsums`. 'SKIP' lets a source build
# proceed without a pinned checksum (acceptable for a VCS-tag tarball).
sha256sums=('SKIP')

prepare() {
    cd "azul-$pkgver"
    # Vendor crates offline-friendly; harmless if the network is available.
    export RUSTUP_TOOLCHAIN=stable
    cargo fetch --locked || cargo fetch
}

build() {
    cd "azul-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    # Regenerate the C-ABI binding sources consumed by build-dll.
    cargo run --release -p azul-doc codegen all
    cargo build --release -p azul-dll --features build-dll
}

package() {
    cd "azul-$pkgver"

    # Shared library.
    install -Dm755 "target/release/libazul.so" \
        "$pkgdir/usr/lib/libazul.so"

    # C / C++ headers (generated by codegen).
    install -Dm644 "target/codegen/azul.h" \
        "$pkgdir/usr/include/azul/azul.h"
    for hpp in azul03 azul11 azul14 azul17 azul20 azul23; do
        if [ -f "target/codegen/$hpp.hpp" ]; then
            install -Dm644 "target/codegen/$hpp.hpp" \
                "$pkgdir/usr/include/azul/$hpp.hpp"
        fi
    done

    # License.
    install -Dm644 "LICENSE" \
        "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
