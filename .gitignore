# Phase-C transpile-blueprint experiment build artifacts.
# third_party/remill is a tracked git submodule (pinned to v6.0.0 —
# v6.0.1 bumped XED 2022 → 2025, breaking the pre-built cxx-common);
# everything else under third_party/ is build output and stays local.
third_party/cxx-common/
third_party/cxx-common-arm64.tar.xz
third_party/remill-install/
experiments/transpile-blueprint/out/
experiments/transpile-blueprint/target/
experiments/transpile-blueprint/Cargo.lock
# Whitelist the cxx shim header — the global `*.h` rule above (intended
# for generated azul.h) would otherwise drop it.
!experiments/transpile-blueprint/cpp/*.h
# Whitelist the in-process remill wrapper headers (M8.9 in-process
# lift). Same reason as the blueprint above — global `*.h` rule
# would otherwise drop them.
!dll/src/web/cpp/*.h

# Compiled per-language e2e test binaries + node deps (regenerated by
# scripts/e2e_language_matrix.sh / npm during local + CI testing).
examples/**/hello-world-e2e
examples/node/node_modules/
examples/node/package-lock.json

# Windows web-lift build artifacts (local; do not track)
/azul.pdb
examples/c/*.pdb
examples/c/*.ilk
