; ============================================================================
; Dune build manifest for the OCaml hello-world example.
; ============================================================================

; The generated azul bindings (azul.ml + azul.mli) defined as a local library.
(library
 (name azul)
 (libraries ctypes ctypes-foreign)
 (modules azul))

(executable
 (name hello_world)
 (modules hello_world)
 (libraries ctypes ctypes-foreign azul))
