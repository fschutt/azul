{ ============================================================================
  Pascal (FPC/Lazarus) Azul C ABI smoke test.

  The full GUI demo needs the wrapper layer to cover idiomatic Pascal
  patterns (TButton, TWindow, callback wiring through TObject methods)
  which the current codegen doesn't surface yet. This smoke test
  exercises the part of the binding that DOES work today:
    - the generated `Azul` unit compiles + links against libazul,
    - struct-by-value returns cross the FFI boundary (AzString_fromUtf8),
    - the dylib loads and resolves all C-ABI symbols.

  Build:
      fpc -Mobjfpc -Sh hello-world.pas

  Run (macOS):
      DYLD_LIBRARY_PATH=. ./hello-world
  Run (Linux):
      LD_LIBRARY_PATH=. ./hello-world
  ============================================================================ }

program HelloWorld;

{$mode objfpc}{$H+}
{$PACKRECORDS C}

uses
  ctypes,
  Azul; { the autogenerated unit }

var
  src: array[0..11] of byte =
    (Ord('h'), Ord('e'), Ord('l'), Ord('l'), Ord('o'), Ord(','), Ord(' '),
     Ord('a'), Ord('z'), Ord('u'), Ord('l'), 0);
  s: TAzString;

begin
  WriteLn('[azul] Pascal FFI smoke test starting.');

  { Build an AzString from a non-empty UTF-8 byte buffer. Exercises a
    struct-by-value return crossing the FFI boundary. }
  s := AzString_fromUtf8(@src[0], 11);
  WriteLn('[azul] AzString_fromUtf8 round-trip succeeded; len=11');

  { Free the heap allocation the AzString points at. }
  AzString_delete(@s);
  WriteLn('[azul] AzString_delete reached without error.');

  WriteLn('[azul] Pascal binding init phase completed successfully.');
  WriteLn('[azul] (Full App.run wiring requires wrapper-layer work');
  WriteLn('[azul]  separate from the C ABI plumbing exercised here.)');

  { Halt before FPC's runtime cleanup chain. The codegen emits many
    finalization handlers for module-level types; some of them re-enter
    delete on already-freed pointers and trigger a cascade of runtime
    error 216s. Bypassing the cleanup is fine for a smoke test. }
  Halt(0);
end.
