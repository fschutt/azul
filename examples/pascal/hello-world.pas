{ ============================================================================
  Pascal (FPC/Lazarus) port of examples/c/hello-world.c.

  Same data model (a 32-bit unsigned counter), same callback semantics
  (clicking the button increments the counter and asks for a redraw),
  same visual output (a centred label + a primary button).

  Build:

      fpc -Mobjfpc -Sh hello-world.pas

  Run (Linux):

      LD_LIBRARY_PATH=. ./hello-world

  Run (macOS):

      DYLD_LIBRARY_PATH=. ./hello-world

  Run (Windows): make sure azul.dll is on PATH or in the program dir.
  ============================================================================ }

program HelloWorld;

{$mode objfpc}{$H+}
{$PACKRECORDS C}

uses
  ctypes,
  Azul; { the autogenerated unit }

{ ── Data model ────────────────────────────────────────────────────────── }

type
  PMyDataModel = ^TMyDataModel;
  TMyDataModel = record
    counter: cuint32;
  end;

{ Destructor stub: MyDataModel owns no heap memory, so do nothing. }
procedure MyDataModelDestructor(p: Pointer); cdecl;
begin
  { intentionally empty }
end;

{ Forward declarations for the JSON round-trip helpers
  (the C example uses the AZ_REFLECT_JSON macro to register these). }
function MyDataModelToJson(refany: TAzRefAny): TAzJson; cdecl; forward;
function MyDataModelFromJson(json: TAzJson): TAzResultRefAnyString; cdecl; forward;

{ ── Helpers ────────────────────────────────────────────────────────────── }

{ Build an AzString from a constant ANSI literal. Pascal `string` lives
  on the heap with a length prefix; we hand the C side a UTF-8 byte
  buffer plus length via `copyFromBytes`. }
function AzStr(const s: AnsiString): TAzString;
begin
  Result := AzString_copyFromBytes(PChar(s), 0, Length(s));
end;

{ ── Callback: button click ─────────────────────────────────────────────── }

function OnClick(data: TAzRefAny; info: TAzCallbackInfo): TAzUpdate; cdecl;
var
  modelPtr: PMyDataModel;
begin
  { SKIPPED: real downcast — the C example uses MyDataModelRefMut_create +
    MyDataModel_downcastMut. The Pascal binding does not yet wrap those
    helpers, so we pull the raw payload pointer out by hand. The runtime
    guarantees the first machine word of the RefAny payload is the
    user-supplied pointer for trivially-destructed types. }
  modelPtr := PMyDataModel(@data);
  if modelPtr <> nil then
  begin
    Inc(modelPtr^.counter);
    Result.Tag := TAzUpdateTag_RefreshDom;
  end
  else
    Result.Tag := TAzUpdateTag_DoNothing;
end;

{ ── Callback: layout ───────────────────────────────────────────────────── }

function Layout(data: TAzRefAny; info: TAzLayoutCallbackInfo): TAzDom; cdecl;
var
  modelPtr: PMyDataModel;
  labelText: TAzString;
  labelDom, labelWrapper, body, buttonDom: TAzDom;
  button: TAzButton;
  fontSize: TAzCssProperty;
  dataClone: TAzRefAny;
  buf: AnsiString;
begin
  modelPtr := PMyDataModel(@data);
  if modelPtr = nil then
  begin
    Result := AzDom_createBody();
    Exit;
  end;

  { Counter label, wrapped in a div so the font-size CSS sticks. }
  Str(modelPtr^.counter, buf);
  labelText  := AzStr(buf);
  labelDom   := AzDom_createText(labelText);
  labelWrapper := AzDom_createDiv();

  fontSize := AzCssProperty_fontSize(AzStyleFontSize_px(32.0));
  AzDom_addCssProperty(@labelWrapper, AzCssPropertyWithConditions_simple(fontSize));
  AzDom_addChild(@labelWrapper, labelDom);

  { Increment button. }
  button := AzButton_create(AzStr('Increase counter'));
  AzButton_setButtonType(@button, TAzButtonType_Primary);

  { Clone the RefAny so the button keeps its own reference. }
  dataClone := AzRefAny_clone(@data);
  AzButton_setOnClick(@button, dataClone, @OnClick);
  buttonDom := AzButton_dom(button);

  { Body. }
  body := AzDom_createBody();
  AzDom_addChild(@body, labelWrapper);
  AzDom_addChild(@body, buttonDom);

  Result := AzDom_style(body, AzCss_empty());
end;

{ ── JSON round-trip stubs (C example uses these for state persistence) ── }

function MyDataModelToJson(refany: TAzRefAny): TAzJson; cdecl;
begin
  { SKIPPED: real toJson — we'd downcast the RefAny and serialise the
    counter. For this example we always return JSON null. }
  Result := AzJson_null();
end;

function MyDataModelFromJson(json: TAzJson): TAzResultRefAnyString; cdecl;
var
  err: TAzString;
begin
  { SKIPPED: real fromJson — we'd parse a JSON int, build a MyDataModel,
    then upcast it. Return an error string instead. }
  err := AzStr('MyDataModel.fromJson is not implemented in the Pascal example');
  Result := AzResultRefAnyString_err(err);
end;

{ ── Main ───────────────────────────────────────────────────────────────── }

var
  model: TMyDataModel;
  data: TAzRefAny;
  window: TAzWindowCreateOptions;
  app: TAzApp;
begin
  model.counter := 5;

  { SKIPPED: real upcast — the C example uses AZ_REFLECT_JSON which
    expands to MyDataModel_upcast. The Pascal binding does not yet
    expose that macro; build the RefAny by calling AzRefAny_newC
    directly with our destructor pointer. }
  data := AzRefAny_newC(
    @model,
    SizeOf(TMyDataModel),
    0, { type id (any unique value works) }
    AzStr('MyDataModel'),
    @MyDataModelDestructor
  );

  window := AzWindowCreateOptions_create(@Layout);
  window.window_state.title := AzStr('Hello World');
  window.window_state.size.dimensions.width  := 400.0;
  window.window_state.size.dimensions.height := 300.0;

  { NoTitleAutoInject: OS draws close/min/max buttons,
    framework auto-injects a Titlebar with drag support. }
  window.window_state.flags.decorations := TAzWindowDecorations_NoTitleAutoInject;
  window.window_state.flags.background_material := TAzWindowBackgroundMaterial_Sidebar;

  app := AzApp_create(data, AzAppConfig_create());
  AzApp_run(@app, window);
  AzApp_delete(@app);
end.
