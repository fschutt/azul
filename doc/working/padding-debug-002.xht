<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
    <head>
        <title>Padding Debug: nested padding without star reset</title>
        <style type="text/css">
            body { margin: 0; width: 800px; height: 600px; padding: 30px; background: #ddd; }
            .outer { padding: 20px; background: blue; }
            .inner { padding: 10px; background: red; width: 200px; height: 50px; }
        </style>
    </head>
    <body>
        <div class="outer">
            <div class="inner"></div>
        </div>
    </body>
</html>
