<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
    <head>
        <title>Font Properties</title>
        <style type="text/css">
            * { margin: 0; padding: 0; }
            body { width: 800px; height: 600px; background: #ffffff; font-family: sans-serif; font-size: 14px; }
            .row { padding: 4px 8px; margin: 2px 0; }
            .w100 { font-weight: 100; }
            .w400 { font-weight: 400; }
            .w700 { font-weight: 700; }
            .w900 { font-weight: 900; }
            .italic { font-style: italic; }
            .sz-px { font-size: 20px; }
            .sz-em { font-size: 1.5em; }
            .sz-pct { font-size: 150%; }
            .al { text-align: left; background: #ffeeee; }
            .ac { text-align: center; background: #eeffee; }
            .ar { text-align: right; background: #eeeeff; }
            .aj { text-align: justify; background: #fff8ee; }
        </style>
    </head>
    <body>
        <div class="row w100">font-weight: 100 (thin)</div>
        <div class="row w400">font-weight: 400 (normal)</div>
        <div class="row w700">font-weight: 700 (bold)</div>
        <div class="row w900">font-weight: 900 (black)</div>
        <div class="row italic">font-style: italic</div>
        <div class="row sz-px">font-size: 20px</div>
        <div class="row sz-em">font-size: 1.5em</div>
        <div class="row sz-pct">font-size: 150%</div>
        <div class="row al">text-align: left</div>
        <div class="row ac">text-align: center</div>
        <div class="row ar">text-align: right</div>
        <div class="row aj">text-align: justify - this line has extra words to show the justify effect across the width.</div>
    </body>
</html>
