<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
    <head>
        <title>Flexbox: Simple Test</title>
        <style type="text/css">
            * { margin: 0; padding: 0; box-sizing: border-box; }
            body {
                width: 800px;
                height: 600px;
                padding: 20px;
                background: #cccccc;
            }
            .container {
                display: flex;
                width: 100%;
                height: 100px;
                background: white;
                border: 5px solid #000;
            }
            .item1 {
                flex-grow: 1;
                background: #ff0000;
                border: 3px solid #880000;
            }
            .item2 {
                flex-grow: 2;
                background: #0000ff;
                border: 3px solid #000088;
            }
            .item3 {
                flex-grow: 3;
                background: #00ff00;
                border: 3px solid #008800;
            }
        </style>
    </head>
    <body>
        <div class="container">
            <div class="item1"></div>
            <div class="item2"></div>
            <div class="item3"></div>
        </div>
    </body>
</html>
