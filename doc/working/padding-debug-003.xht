<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
    <head>
        <title>Padding Debug: large visible padding on div (no star reset)</title>
        <style type="text/css">
            body { margin: 0; padding: 0; width: 800px; height: 600px; background: white; }
            .padded { padding: 50px; background: #ff0000; width: 300px; }
            .content { background: #00ff00; width: 100px; height: 50px; }
        </style>
    </head>
    <body>
        <div class="padded">
            <div class="content"></div>
        </div>
    </body>
</html>
