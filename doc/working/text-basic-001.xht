<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
    <head>
        <title>Basic Text Rendering</title>
        <style type="text/css">
            * { margin: 0; padding: 0; }
            body { width: 800px; height: 600px; background: #ffffff; font-family: sans-serif; }
            h1 { font-size: 32px; color: #cc0000; }
            h2 { font-size: 28px; color: #0000cc; }
            h3 { font-size: 24px; color: #00aa00; }
            h4 { font-size: 20px; color: #cc6600; }
            h5 { font-size: 16px; color: #6600cc; }
            h6 { font-size: 14px; color: #009999; }
            p { font-size: 14px; color: #333333; margin-top: 4px; }
            .bold { font-weight: bold; color: #000000; }
            .italic { font-style: italic; color: #555555; }
            .large { font-size: 24px; color: #990066; }
            .small { font-size: 10px; color: #666666; }
        </style>
    </head>
    <body>
        <h1>Heading 1</h1>
        <h2>Heading 2</h2>
        <h3>Heading 3</h3>
        <h4>Heading 4</h4>
        <h5>Heading 5</h5>
        <h6>Heading 6</h6>
        <p>Normal paragraph text in default size.</p>
        <p class="bold">Bold paragraph text.</p>
        <p class="italic">Italic paragraph text.</p>
        <p class="large">Large font size text.</p>
        <p class="small">Small font size text.</p>
    </body>
</html>
