<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
    <head>
        <title>Text in Box Debug</title>
        <style type="text/css">
            * { margin: 0; padding: 0; }
            body { width: 800px; height: 600px; background: white; font-size: 24px; }
            .red { background: #ff0000; width: 300px; height: 80px; padding: 10px; color: #000000; font-weight: bold; }
            .blue { background: #0000ff; width: 300px; height: 80px; padding: 10px; color: #ffff00; font-weight: bold; }
            .plain { width: 300px; height: 80px; padding: 10px; border: 3px solid #000; font-weight: bold; }
        </style>
    </head>
    <body>
        <div class="plain">BLACK TEXT NO BG</div>
        <div class="red">BLACK TEXT RED BG</div>
        <div class="blue">YELLOW TEXT BLUE BG</div>
    </body>
</html>
