<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
    <head>
        <title>Block Padding and Border</title>
        <style type="text/css">
            * { margin: 0; padding: 0; }
            body { width: 800px; height: 600px; background: #ffffff; font-family: sans-serif; }
            .outer {
                padding: 20px;
                border: 4px solid #cc0000;
                background: #ffeeee;
                margin: 10px;
            }
            .middle {
                padding: 15px;
                border: 3px dashed #0000cc;
                background: #eeeeff;
            }
            .inner {
                padding: 10px;
                border: 2px dotted #00aa00;
                background: #eeffee;
            }
            .thick-border {
                margin: 10px;
                padding: 12px;
                border-width: 8px;
                border-style: solid;
                border-color: #cc6600 #6600cc #009999 #990066;
                background: #fff8ee;
            }
        </style>
    </head>
    <body>
        <div class="outer">
            Outer (solid red 4px, padding 20px)
            <div class="middle">
                Middle (dashed blue 3px, padding 15px)
                <div class="inner">Inner (dotted green 2px, padding 10px)</div>
            </div>
        </div>
        <div class="thick-border">Thick multi-color border (8px each side different color)</div>
    </body>
</html>
