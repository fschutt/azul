<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
    <head>
        <title>Basic Table</title>
        <style type="text/css">
            * { margin: 0; padding: 0; }
            body { width: 800px; height: 600px; background: #ffffff; font-family: sans-serif; font-size: 14px; }
            table { border-collapse: collapse; margin: 20px; width: 400px; }
            th { background: #333333; color: #ffffff; padding: 10px; border: 2px solid #000000; text-align: left; }
            td { padding: 8px; border: 1px solid #999999; }
            .r1 { background: #ffcccc; }
            .r2 { background: #ccffcc; }
            .r3 { background: #ccccff; }
        </style>
    </head>
    <body>
        <table>
            <thead>
                <tr><th>Header A</th><th>Header B</th><th>Header C</th></tr>
            </thead>
            <tbody>
                <tr class="r1"><td>Red 1</td><td>Red 2</td><td>Red 3</td></tr>
                <tr class="r2"><td>Green 1</td><td>Green 2</td><td>Green 3</td></tr>
                <tr class="r3"><td>Blue 1</td><td>Blue 2</td><td>Blue 3</td></tr>
            </tbody>
        </table>
    </body>
</html>
