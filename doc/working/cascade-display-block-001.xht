<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
    <head>
        <title>Display Block UA Defaults</title>
        <style type="text/css">
            * { margin: 0; padding: 0; }
            body { width: 800px; height: 600px; background: #ffffff; font-family: sans-serif; font-size: 14px; }
            .bg-red { background: #ffdddd; }
            .bg-blue { background: #ddddff; }
            .bg-green { background: #ddffdd; }
            .bg-yellow { background: #ffffdd; }
            .bg-purple { background: #ffddff; }
            .bg-cyan { background: #ddffff; }
            .bg-orange { background: #ffeecc; }
        </style>
    </head>
    <body>
        <h1 class="bg-red">H1: must be display:block (full-width red bg)</h1>
        <h2 class="bg-blue">H2: must be display:block (full-width blue bg)</h2>
        <h3 class="bg-green">H3: must be display:block (full-width green bg)</h3>
        <h4 class="bg-yellow">H4: must be display:block (full-width yellow bg)</h4>
        <h5 class="bg-purple">H5: must be display:block (full-width purple bg)</h5>
        <h6 class="bg-cyan">H6: must be display:block (full-width cyan bg)</h6>
        <p class="bg-orange">P: must be display:block (full-width orange bg)</p>
        <div class="bg-red">DIV: must be display:block (full-width red bg)</div>
        <span class="bg-blue">SPAN1: inline</span>
        <span class="bg-green">SPAN2: inline (same line as SPAN1)</span>
        <div class="bg-yellow">DIV after spans: new block line (full-width yellow bg)</div>
    </body>
</html>
