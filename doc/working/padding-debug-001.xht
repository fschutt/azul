<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
    <head>
        <title>Padding Debug: body padding with star reset</title>
        <style type="text/css">
            * { margin: 0; padding: 0; }
            body { width: 800px; height: 600px; padding: 40px; background: #ccc; }
            .box { width: 200px; height: 100px; background: red; }
        </style>
    </head>
    <body>
        <div class="box"></div>
    </body>
</html>
