<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
    <head>
        <title>Showcase: Complex Flexbox Layout</title>
        <style type="text/css">
            * { margin: 0; padding: 0; box-sizing: border-box; }
            body { width: 800px; height: 600px; background: #ddd; }
            .container {
                display: flex;
                width: 100%;
                height: 100%;
                flex-direction: column;
                padding: 10px;
                background: #bbb;
                border: 5px solid #000;
            }
            .header {
                display: flex;
                height: 60px;
                background: #ff0000;
                border: 3px solid #800000;
                margin-bottom: 10px;
                justify-content: space-between;
                align-items: center;
                padding: 0 10px;
            }
            .header-item {
                width: 30px;
                height: 30px;
                background: #ffff00;
                border: 2px solid #888800;
                margin-left: 5px;
            }
            .content {
                display: flex;
                flex: 1;
            }
            .sidebar {
                display: flex;
                flex-direction: column;
                width: 150px;
                background: #0000ff;
                border: 3px solid #000080;
                padding: 10px;
                margin-right: 10px;
            }
            .sidebar-item {
                height: 40px;
                background: #00ffff;
                border: 2px solid #008888;
                margin-bottom: 8px;
            }
            .main {
                display: flex;
                flex: 1;
                flex-wrap: wrap;
                align-content: flex-start;
            }
            .card {
                display: flex;
                flex-direction: column;
                width: 200px;
                height: 120px;
                background: #ffffff;
                border: 3px solid #00aa00;
                padding: 8px;
                margin-right: 10px;
                margin-bottom: 10px;
            }
            .card-top {
                height: 30px;
                background: #00ff00;
                border: 2px solid #006600;
                margin-bottom: 5px;
            }
            .card-mid {
                flex: 1;
                background: #ff00ff;
                border: 2px solid #880088;
            }
            .card-bot {
                height: 20px;
                background: #ff8800;
                border: 2px solid #884400;
                margin-top: 5px;
            }
            .footer {
                display: flex;
                height: 50px;
                background: #333333;
                border: 3px solid #000;
                margin-top: 10px;
                justify-content: center;
                align-items: center;
            }
            .footer-item {
                width: 60px;
                height: 25px;
                background: #666666;
                border: 2px solid #999;
                margin-left: 15px;
            }
        </style>
    </head>
    <body>
        <div class="container">
            <div class="header">
                <div style="display:flex;">
                    <div class="header-item"></div>
                    <div class="header-item"></div>
                    <div class="header-item"></div>
                </div>
                <div style="display:flex;">
                    <div class="header-item"></div>
                    <div class="header-item"></div>
                </div>
            </div>
            <div class="content">
                <div class="sidebar">
                    <div class="sidebar-item"></div>
                    <div class="sidebar-item"></div>
                    <div class="sidebar-item"></div>
                    <div class="sidebar-item"></div>
                </div>
                <div class="main">
                    <div class="card">
                        <div class="card-top"></div>
                        <div class="card-mid"></div>
                        <div class="card-bot"></div>
                    </div>
                    <div class="card">
                        <div class="card-top"></div>
                        <div class="card-mid"></div>
                        <div class="card-bot"></div>
                    </div>
                    <div class="card">
                        <div class="card-top"></div>
                        <div class="card-mid"></div>
                        <div class="card-bot"></div>
                    </div>
                    <div class="card">
                        <div class="card-top"></div>
                        <div class="card-mid"></div>
                        <div class="card-bot"></div>
                    </div>
                </div>
            </div>
            <div class="footer">
                <div class="footer-item"></div>
                <div class="footer-item"></div>
                <div class="footer-item"></div>
            </div>
        </div>
    </body>
</html>
